# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only. Never expose to the browser. Used for admin/service operations
# (e.g. registering scans and feedback via API without a logged-in user).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- App ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Stripe (klargjort - kode er klar, mangler kun konto + nøgler) ---
# Server-only hemmeligheder. Udfyld når Stripe-kontoen er oprettet.
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# Offentlig nøgle (må gerne eksponeres i browseren).
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- Resend (Sprint 2 - not used yet) ---
# RESEND_API_KEY=
